{
  "name": "toolport-openapi-mcp",
  "version": "0.2.0",
  "description": "Turn any OpenAPI/Swagger spec into an MCP server: one tool per endpoint. A showcase for Toolport (toolport.app).",
  "type": "module",
  "bin": {
    "toolport-openapi-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openapi",
    "swagger",
    "rest",
    "api",
    "ai-tools",
    "toolport"
  ],
  "author": "South Forge AI",
  "license": "MIT",
  "homepage": "https://toolport.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsouth89/toolport-openapi-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/tsouth89/toolport-openapi-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
